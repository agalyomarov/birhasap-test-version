{
   "$schema": "../node_modules/@tauri-apps/cli/config.schema.json",
   "productName": "Birhasap test version",
   "version": "0.1.0",
   "identifier": "com.tauri.birhasap-test-version",
   "build": {
      "frontendDist": "../dist",
      "devUrl": "http://localhost:3000",
      "beforeDevCommand": "npm run dev",
      "beforeBuildCommand": "npm run generate"
   },
   "app": {
      "windows": [
         {
            "title": "main",
            "width": 370,
            "height": 222,
            "minWidth": 370,
            "minHeight": 222,
            "resizable": false,
            "fullscreen": false,
            "decorations": false,
            "url": "/login",
            "alwaysOnTop": true,
            "hiddenTitle": true,
            "titleBarStyle": "Overlay"
         }
      ],
      "security": {
         "csp": null
      }
   },
   "bundle": {
      "active": true,
      "targets": "all",
      "icon": ["icons/32x32.png", "icons/128x128.png", "icons/128x128@2x.png", "icons/icon.icns", "icons/icon.ico"],
      "android": {
         "debugApplicationIdSuffix": ".debug"
      }
   }
}
